    Baixo -- "ruim em" --> R4["3. Salto de fase<br/>4. RoCoF alto<br/>(perde lock)"]:::bad

    classDef a fill:#d3f9d8,stroke:#2f9e44,color:#000
    classDef b fill:#dbe4ff,stroke:#364fc7,color:#000
